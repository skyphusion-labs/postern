# Keep the build context (and thus the image) lean and source-tree-free. The build
# only needs pyproject.toml, the posternimap package, README.md (pyproject readme),
# and docker-entrypoint.sh. Everything below is host-install cruft or local build
# state that must never enter the image.
build/
dist/
*.egg-info/
.mypy_cache/
.pytest_cache/
__pycache__/
*.pyc
_trial_temp/
_trial_temp*/
.env
.env.*
!.env.example
systemd/
.venv/
venv/
