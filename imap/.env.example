# postern-imap configuration (copy to a systemd EnvironmentFile or export these).
# Only POSTERN_API_URL is always required.

# Where the Postern mailbox API lives (the worker origin).
POSTERN_API_URL=https://postern.example

# Auth mode: token (default) | fixed | native | ldap | system. See README
# "Auth model (#32, expanded for #77)" in README.md for the posture of each.
#   token:  the IMAP password IS the Postern API token; nothing secret stored here.
#   fixed:  the proxy holds the token; clients log in with a normal username/password.
#   native: validate the login against the worker POST /api/smtp-auth, then read the
#           store with a per-function service token (mirrors the SMTP relay).
#   ldap:   bind the login against the directory over TLS, then read with the token.
#   system: authenticate the login against local Unix accounts (PAM), then read.
POSTERN_IMAP_AUTH_MODE=token

# --- fixed mode ---
# POSTERN_IMAP_USERNAME=conrad
# POSTERN_API_TOKEN=replace-with-the-postern-api-token

# --- native / ldap / system: the per-function SERVICE token the proxy reads the
# store with AFTER authenticating the user (age-encrypted at deploy, labeled by
# function; NEVER a plaintext secret in git). Same env var as fixed mode.
# POSTERN_API_TOKEN=replace-with-the-per-function-service-token

# --- optional EXPUNGE delete token (#278): a member of the worker POSTERN_API_TOKEN
# (`both`) set. The read token above cannot DELETE; wire this separately so EXPUNGE
# works without widening the read-scoped token. Swarm: postern_imap_delete_token.
# POSTERN_API_TOKEN_DELETE=replace-with-the-imap-delete-member

# --- optional IMAP-service write token (#352): the `imap`-scoped worker slot
# (POSTERN_API_TOKEN_IMAP). Enables durable Drafts / APPEND import; without it the
# door refuses those writes rather than silently discarding. Own slot, NOT a member
# of POSTERN_API_TOKEN. Swarm: postern_imap_imap_token.
# POSTERN_API_TOKEN_IMAP=replace-with-the-imap-service-token

# --- native mode (mirrors the relay AUTH_BACKEND=native) ---
# POST {username, secret} to the worker, gated by the transport token.
# POSTERN_TRANSPORT_TOKEN=replace-with-the-transport-secret
# POSTERN_SMTP_AUTH_URL defaults to ${POSTERN_API_URL}/api/smtp-auth; override if
# the auth endpoint lives elsewhere.
# POSTERN_SMTP_AUTH_URL=https://postern.example/api/smtp-auth

# --- ldap mode (mirrors the relay AUTH_BACKEND=ldap; TLS is mandatory) ---
# Needs ldap3: pip install -e '.[ldap]'
# LDAP_URL=ldaps://dir.your-domain:636
# LDAP_STARTTLS=false
# Direct-bind + self-read is the ONLY bind mode (#182, byte-symmetric with the
# relay; the search+bind vars LDAP_BIND_DN / LDAP_BIND_PASSWORD / LDAP_SEARCH_*
# are retired and refuse startup):
# LDAP_BIND_DN_TEMPLATE=cn=%s,ou=users,dc=example,dc=com
# Optional fail-closed authz gate: the bound user must carry this group DN in
# LDAP_GROUP_ATTR on a self-read of their own entry (empty = no gate).
# LDAP_REQUIRE_GROUP=cn=mail-users,ou=groups,dc=example,dc=com
# LDAP_GROUP_ATTR=memberOf
# TLS trust to the directory (#153) -- set ONE (they are mutually exclusive).
# Neither set = the channel is encrypted but UNAUTHENTICATED (loud startup
# warning). The pin is a NON-secret public value.
# LDAP_TLS_CA=/etc/postern-imap/ldap-ca.pem
# LDAP_TLS_SERVER_NAME=dir.your-domain
# LDAP_TLS_PIN_SHA256=AA:BB:...  (openssl x509 -fingerprint -sha256 output)
# LDAP connect + bind/search timeout, seconds (0 = none). Shared knob name
# with the Go relay; keep both sides equal.
# LDAP_TIMEOUT=10

# --- system mode (mirrors the relay AUTH_BACKEND=system; local Unix via PAM) ---
# Needs python-pam: pip install -e '.[pam]'
# AUTH_SYSTEM_PAM_SERVICE=postern
# AUTH_SYSTEM_DOMAIN=skyphusion.org

# Listener (default loopback:1143). Bind beyond loopback only behind TLS.
POSTERN_IMAP_HOST=127.0.0.1
POSTERN_IMAP_PORT=1143

# Optional IMAPS: set BOTH for TLS on the listener. Exposing 993 is gated; see
# DEPLOY.md. For local testing use a self-signed cert on loopback only.
# POSTERN_IMAP_TLS_CERT=/etc/postern-imap/cert.pem
# POSTERN_IMAP_TLS_KEY=/etc/postern-imap/key.pem

# Per-request timeout to the Postern API, seconds.
POSTERN_API_TIMEOUT=15

# Mailbox windowing + live refresh (#102). INBOX/Sent show the most-recent
# POSTERN_IMAP_WINDOW messages at SELECT (0 = unlimited); the All folder is
# always unbounded, so older mail is reachable there or by raising the window.
POSTERN_IMAP_WINDOW=500
# While a mailbox is selected, re-poll the store every N seconds and push an
# untagged EXISTS when new mail arrives, so MUAs (and IDLE) see it mid-session.
# 0 disables the poll (clients then refresh on their own re-SELECT).
POSTERN_IMAP_POLL_SECONDS=30

# Mailbox UIDVALIDITY (RFC 3501): a positive 32-bit value, constant across reconnects
# so a client's cached UID->message map stays valid. BUMP THIS (to any higher value)
# whenever a deploy changes the server-side PROJECTION of existing messages (their
# BODY[]/RFC822.SIZE under the same UID); a bump tells clients to discard cached bodies
# and re-fetch, per the RFC message-immutability rule. Deploying the #210 HTML/8bit
# projection fix REQUIRES a bump. Default 1 (historical); leave as-is until a projection
# change ships.
POSTERN_IMAP_UIDVALIDITY=1

# Auth brute-force throttle (#105). Door-agnostic AUTH_THROTTLE_* names, integer
# seconds, identical to the SMTP relay so one vocabulary configures both doors.
# AUTH_THROTTLE_ENABLED=true
# AUTH_THROTTLE_MAX_FAILURES=5
# AUTH_THROTTLE_LOCKOUT_SECONDS=60
# AUTH_THROTTLE_MAX_LOCKOUT_SECONDS=900
# AUTH_THROTTLE_GLOBAL_MAX_FAILURES=100
# AUTH_THROTTLE_GLOBAL_WINDOW_SECONDS=60

# --- PROXY protocol (real client IP behind the L4 load balancer, #155) -------
# The mail edge moved to a single L4 load balancer that targets the directory host
# directly (no bastion). An L4 LB rewrites the source address, so the door recovers
# the REAL client IP from a PROXY header the LB prepends, HONORED ONLY from a
# trusted source (anti-spoof). On 993 the header precedes the TLS handshake; the
# door strips it off the raw stream first. Config names are shared 1:1 with the Go
# 587 door; full contract in docs/PROXY-PROTOCOL.md.
#   off      = disabled; raw peer always (DEFAULT; correct for mesh-internal / dev direct)
#   optional = trusted peer MAY send a header; a missing header falls back to raw peer
#   require  = trusted peer MUST send a header; trusted-without-header and any
#              untrusted peer are rejected (the production posture once the LB is live)
# PROXY_PROTOCOL_TRUSTED is REQUIRED whenever the mode is optional/require: the LB's
# private source as a comma-separated CIDR list (a bare IP = /32 or /128).
# PROXY_PROTOCOL=off
# PROXY_PROTOCOL_TRUSTED=192.0.2.0/24
# PROXY_PROTOCOL_TIMEOUT_SECONDS=5           # bound on reading the header (floored at 1s)
