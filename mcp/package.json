{
  "name": "postern-mcp",
  "version": "1.1.0",
  "description": "Model Context Protocol server for Postern: read tools over the mailbox API (search/list/get/thread), plus optional send tools (mailbox_send / mailbox_reply) behind a send-scoped token.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "postern-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "node scripts/stdio-smoke.mjs",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.9"
  }
}
