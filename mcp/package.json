{
  "name": "@skyphusion/postern-mcp",
  "version": "1.2.0",
  "description": "Model Context Protocol server for Postern: read tools over the mailbox API (search/list/get/thread/get_attachment), plus optional send tools (mailbox_send / mailbox_reply, with attachments) behind a send-scoped token.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skyphusion-labs/postern.git",
    "directory": "mcp"
  },
  "homepage": "https://github.com/skyphusion-labs/postern/tree/main/mcp#readme",
  "bugs": {
    "url": "https://github.com/skyphusion-labs/postern/issues"
  },
  "keywords": [
    "mcp",
    "postern",
    "email",
    "mailbox",
    "model-context-protocol"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "postern-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "node scripts/stdio-smoke.mjs",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
