# Postern MCP server config. The MCP client (e.g. Claude Code) passes these in
# its server "env" block; this file is only a reference. NEVER commit a real token.

# The Postern mailbox API origin (the inbound Worker).
POSTERN_API_URL=https://your-postern-api.workers.dev

# A READ-scoped Postern API token (#85). Sent as Authorization: Bearer on the
# read tools (search/list/get/thread). Required.
POSTERN_API_TOKEN=

# OPTIONAL, OPT-IN, MUTATING: a SEND-scoped Postern API token (#85). When set, the
# server additionally registers the send tools (mailbox_send / mailbox_reply) and
# uses THIS token for them. Leave it unset to run the read-only server (the default).
# Send tools actually deliver mail as the estate, so enable this deliberately.
# POSTERN_SEND_TOKEN=

# Optional: per-request timeout in milliseconds (default 15000).
# POSTERN_API_TIMEOUT_MS=15000
