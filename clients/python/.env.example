# postern-client configuration. Export these (or source this file) before use.
# PER-USER OWN KEY: bring your own token; nothing is hardcoded or shared.

# The Postern mailbox API origin (the inbound/store worker). Loopback/mesh only
# per the project's exposure posture; do NOT point this at a public listener.
POSTERN_API_URL=https://postern.example

# Your Postern API token (secret). Never commit a real value; never echo it.
# Presence-check in shell glue with ${POSTERN_API_TOKEN:+SET}, never ${VAR:-...}.
POSTERN_API_TOKEN=replace-with-your-postern-api-token

# Optional: per-request timeout in seconds (default 30).
# POSTERN_API_TIMEOUT=30
