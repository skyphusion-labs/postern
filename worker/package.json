{
  "name": "skyphusion-email",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker that sends transactional email via Cloudflare Email Sending",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.enabled=true --coverage.provider=istanbul --coverage.reporter=cobertura --coverage.reporter=text",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250505.0",
    "@vitest/coverage-istanbul": "^4.1.9",
    "typescript": "^5.5.4",
    "vitest": "^4.1.9",
    "wrangler": "^4.102.0"
  }
}
