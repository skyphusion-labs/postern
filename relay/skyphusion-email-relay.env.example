# Copy to /etc/skyphusion-email-relay.env and fill in. Read by the systemd unit.
# Keep mode 0600 (it holds the transport token).
#
# The relay is Postern's transport bridge (docs/CONTRACT.md). It does two things:
#   INBOUND  : accepts local SMTP and POSTs each message to core's /ingest seam.
#   OUTBOUND : (optional) accepts an OutboundMessage from core over HTTP and
#              sends it through a bring-your-own upstream SMTP server.

# ---- Inbound seam (preferred: the M3 /ingest path) -------------------------

# Core's /ingest endpoint (the inbound transport seam, CONTRACT section 2).
POSTERN_INGEST_URL=https://postern.<account>.workers.dev/ingest

# The TRANSPORT token. Gates /ingest and the outbound /dispatch bridge. This is
# NOT the mailbox API token (POSTERN_API_TOKEN): transports are infra, not API
# clients, so a leak of one cannot compromise the other (CONTRACT section 5/8).
POSTERN_TRANSPORT_TOKEN=replace-with-transport-secret

# ---- Inbound seam (legacy fallback) ----------------------------------------
# If POSTERN_INGEST_URL is unset, the relay falls back to posting an EmailPayload
# to the worker /send endpoint (pre-M3 behavior). Set EITHER the ingest pair
# above OR this legacy pair, not both.
# EMAIL_WORKER_URL=https://skyphusion-email.<account>.workers.dev/send
# EMAIL_RELAY_TOKEN=replace-with-legacy-shared-secret
# DEFAULT_FROM=noreply@skyphusion.org   # legacy /send rewrites off-domain From
# FROM_DOMAIN=skyphusion.org            # the only sender domain the worker accepts

# ---- SMTP listener (inbound intake) ----------------------------------------

# Where the relay listens for local SMTP. The intake door is UNAUTHENTICATED by
# design, so it is LOOPBACK-ONLY by enforced invariant (audit F4): the relay
# REFUSES to start if any bind is non-loopback (a wildcard ":2525", 0.0.0.0, or a
# routable IP). Comma-separated loopback aliases are fine. A caller that cannot
# reach loopback (e.g. a separate container) must front the intake with an
# authenticated proxy, not bind it on a routable interface.
SMTP_LISTEN=127.0.0.1:2525

# Max accepted message size in bytes (default 25 MiB).
# MAX_MESSAGE_BYTES=26214400

# ---- Outbound seam (optional BYO-SMTP /dispatch bridge) --------------------
# Enable this only if core is configured with OUTBOUND_TRANSPORT=relay and a
# RelayTransport pointed at this address. Leave POSTERN_RELAY_HTTP_LISTEN unset
# to run inbound-only.

# Where the relay listens for OutboundMessage POSTs from core (token-gated).
# POSTERN_RELAY_HTTP_LISTEN=127.0.0.1:2526

# The upstream SMTP server the relay sends OUTBOUND mail through.
# SMTP_OUT_HOST=smtp.your-provider.example
# SMTP_OUT_PORT=587
# SMTP_OUT_USERNAME=apikey-or-user      # optional; PLAIN auth used when set
# SMTP_OUT_PASSWORD=secret
# SMTP_OUT_STARTTLS=true                 # require STARTTLS (default true)
# SMTP_OUT_TIMEOUT_SECONDS=30

# Fallback envelope From if an OutboundMessage carries none (core normally fills it).
# POSTERN_OUTBOUND_FROM=noreply@skyphusion.org

# Outbound HTTP timeout for POSTs the relay makes to core (default 30s).
# HTTP_TIMEOUT_SECONDS=30

# ---- Submission seam (optional: authenticated SMTP submission for clients) --
# Issue #68. Lets a normal IMAP client (Thunderbird / Apple Mail / mobile) send
# AS your own domain over authenticated submission that bridges to the worker
# /api/send seam. Enable by setting SUBMISSION_LISTENERS. Domain-agnostic: the
# bound identity comes from the auth backend, so this works for any operator.
#
# UNLIKE the inbound intake listener above (loopback only, open-relay risk),
# these listeners are AUTH-REQUIRED, so binding them publicly is correct. AUTH is
# offered ONLY over TLS, so a real certificate is required (cleartext AUTH -> 523).

# An ARBITRARY set of "<addr>:<mode>" listeners (mode = starttls | implicit). A
# bare port means ":<port>" (all interfaces). 587/465 are canonical, but add any
# alternate port to dodge ISP/provider blocking of 25/587. Examples:
#   587:starttls,465:implicit         (canonical)
#   587:starttls,465:implicit,2525:starttls   (plus an alternate)
#   0.0.0.0:587:starttls,127.0.0.1:8025:implicit
# SUBMISSION_LISTENERS=587:starttls,465:implicit

# TLS cert + key (PEM) for the submission hostname (e.g. smtp.your-domain). The
# daemon HOT-RELOADS the cert when the file changes, so a renewal needs no
# restart. HOW you obtain/renew the cert is YOUR choice (certbot, acme.sh, a
# commercial cert, self-signed for testing); the daemon only reads these paths.
# SUBMISSION_TLS_CERT=/etc/postern/submission/fullchain.pem
# SUBMISSION_TLS_KEY=/etc/postern/submission/privkey.pem

# SMTP greeting hostname (cosmetic; default localhost).
# SUBMISSION_HOSTNAME=smtp.your-domain

# The worker outbound send seam (DKIM-signs + stores the sent copy). Used by every
# auth backend. POSTERN_SEND_TOKEN is the worker's mailbox API token
# (POSTERN_API_TOKEN value), NOT the transport token.
# POSTERN_SEND_URL=https://postern.<account>.workers.dev/api/send
# POSTERN_SEND_TOKEN=replace-with-mailbox-api-token

# ---- Auth backend: native (default) | ldap | system --------------------------
# AUTH_BACKEND=native

# native: validate the login at the worker /api/smtp-auth (D1 smtp_credentials,
# PBKDF2-hashed). Gated by POSTERN_TRANSPORT_TOKEN (set above). Zero extra deps;
# this is the fresh-clone default.
# POSTERN_SMTP_AUTH_URL=https://postern.<account>.workers.dev/api/smtp-auth

# ldap: simple-bind or search+bind over TLS (pure-Go go-ldap). The bound identity
# is the user's mail attribute. TLS is mandatory (ldaps:// or LDAP_STARTTLS=true).
# LDAP_URL=ldaps://dir.your-domain:636
# LDAP_STARTTLS=false
# Simple bind (one of the two modes):
# LDAP_BIND_DN_TEMPLATE=uid=%s,ou=people,dc=example,dc=com
# Search+bind (the other mode; a service account searches, then the user binds):
# LDAP_BIND_DN=cn=svc,dc=example,dc=com
# LDAP_BIND_PASSWORD=service-account-password
# LDAP_SEARCH_BASE=ou=people,dc=example,dc=com
# LDAP_SEARCH_FILTER=(uid=%s)
# LDAP_MAIL_ATTR=mail

# system: local Unix accounts via PAM. REQUIRES a build with -tags pam (the
# default binary is cgo-free and rejects this backend). Bound identity =
# <user>@AUTH_SYSTEM_DOMAIN. Needs a PAM service file (default /etc/pam.d/postern).
# AUTH_SYSTEM_DOMAIN=your-domain
# AUTH_SYSTEM_PAM_SERVICE=postern
