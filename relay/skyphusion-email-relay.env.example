# Copy to /etc/skyphusion-email-relay.env and fill in. Read by the systemd unit.
# Keep mode 0600 (it holds the transport token).
#
# The relay is Postern's transport bridge (docs/CONTRACT.md). It does two things:
#   INBOUND  : accepts local SMTP and POSTs each message to core's /ingest seam.
#   OUTBOUND : (optional) accepts an OutboundMessage from core over HTTP and
#              sends it through a bring-your-own upstream SMTP server.

# ---- Inbound seam (preferred: the M3 /ingest path) -------------------------

# Core's /ingest endpoint (the inbound transport seam, CONTRACT section 2).
POSTERN_INGEST_URL=https://postern.<account>.workers.dev/ingest

# The TRANSPORT token. Gates /ingest and the outbound /dispatch bridge. This is
# NOT the mailbox API token (POSTERN_API_TOKEN): transports are infra, not API
# clients, so a leak of one cannot compromise the other (CONTRACT section 5/8).
POSTERN_TRANSPORT_TOKEN=replace-with-transport-secret

# ---- Inbound seam (legacy fallback) ----------------------------------------
# If POSTERN_INGEST_URL is unset, the relay falls back to posting an EmailPayload
# to the worker /send endpoint (pre-M3 behavior). Set EITHER the ingest pair
# above OR this legacy pair, not both.
# EMAIL_WORKER_URL=https://skyphusion-email.<account>.workers.dev/send
# EMAIL_RELAY_TOKEN=replace-with-legacy-shared-secret
# DEFAULT_FROM=noreply@skyphusion.org   # legacy /send rewrites off-domain From
# FROM_DOMAIN=skyphusion.org            # the only sender domain the worker accepts

# ---- SMTP listener (inbound intake) ----------------------------------------

# Where the relay listens for local SMTP. Comma-separated for multiple binds:
# loopback for host services, plus a docker-bridge IP if a container needs to
# reach it. Bind specific private IPs, never 0.0.0.0.
SMTP_LISTEN=127.0.0.1:2525

# Max accepted message size in bytes (default 25 MiB).
# MAX_MESSAGE_BYTES=26214400

# ---- Outbound seam (optional BYO-SMTP /dispatch bridge) --------------------
# Enable this only if core is configured with OUTBOUND_TRANSPORT=relay and a
# RelayTransport pointed at this address. Leave POSTERN_RELAY_HTTP_LISTEN unset
# to run inbound-only.

# Where the relay listens for OutboundMessage POSTs from core (token-gated).
# POSTERN_RELAY_HTTP_LISTEN=127.0.0.1:2526

# The upstream SMTP server the relay sends OUTBOUND mail through.
# SMTP_OUT_HOST=smtp.your-provider.example
# SMTP_OUT_PORT=587
# SMTP_OUT_USERNAME=apikey-or-user      # optional; PLAIN auth used when set
# SMTP_OUT_PASSWORD=secret
# SMTP_OUT_STARTTLS=true                 # require STARTTLS (default true)
# SMTP_OUT_TIMEOUT_SECONDS=30

# Fallback envelope From if an OutboundMessage carries none (core normally fills it).
# POSTERN_OUTBOUND_FROM=noreply@skyphusion.org

# Outbound HTTP timeout for POSTs the relay makes to core (default 30s).
# HTTP_TIMEOUT_SECONDS=30

# ---- Submission seam (optional: authenticated SMTP submission for clients) --
# Issue #68. Lets a normal IMAP client (Thunderbird / Apple Mail / mobile) send
# AS @skyphusion.org over an authenticated submission endpoint that bridges to
# the worker /api/send seam. Enable by setting at least one listener below.
#
# UNLIKE the inbound intake listener above (loopback only, open-relay risk),
# these listeners are AUTH-REQUIRED, so binding them publicly is correct and
# expected (clients connect over the internet). AUTH is offered ONLY over TLS, so
# a real certificate is required (a cleartext AUTH attempt is answered 523).

# 587 = STARTTLS upgrade; 465 = implicit TLS from the first byte. Set either or
# both. Bind 0.0.0.0 here is acceptable because every command past EHLO requires
# AUTH (the open-relay rule applies to the unauthenticated intake listener only).
# POSTERN_SUBMISSION_STARTTLS_LISTEN=:587
# POSTERN_SUBMISSION_TLS_LISTEN=:465

# TLS certificate + private key (PEM) for the submission hostname (e.g.
# smtp.skyphusion.org). Strummer provisions the real cert. Restart the relay to
# pick up a renewed cert.
# POSTERN_SUBMISSION_TLS_CERT=/etc/postern/submission/fullchain.pem
# POSTERN_SUBMISSION_TLS_KEY=/etc/postern/submission/privkey.pem

# The bound-identity domain (the worker enforces it too). Default skyphusion.org.
# POSTERN_SUBMISSION_FROM_DOMAIN=skyphusion.org

# The worker per-user auth check. Gated by POSTERN_TRANSPORT_TOKEN (set above).
# POSTERN_SMTP_AUTH_URL=https://postern.<account>.workers.dev/api/smtp-auth

# The worker outbound send seam (DKIM-signs + stores the sent copy). POSTERN_SEND_TOKEN
# is the worker's mailbox API token (POSTERN_API_TOKEN value), NOT the transport token.
# POSTERN_SEND_URL=https://postern.<account>.workers.dev/api/send
# POSTERN_SEND_TOKEN=replace-with-mailbox-api-token
