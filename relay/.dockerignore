# Keep the build context lean. The build needs go.mod/go.sum, the Go sources, and
# docker-entrypoint.sh. Everything below is host-install cruft, local build state,
# or secret-bearing material that must never enter the build context or the image.
relay
*.test
*.out
.env
.env.*
!.env.example
*.env
!*.env.example
systemd/
README.md
