# Copy to /etc/postern-submission.env (root 0600). Read by postern-submission.service.
# This is the 587 authenticated SMTP submission door (the relay binary built `-tags pam`).
# It is a SEPARATE instance from the loopback inbound relay; do not collide its ports.
#
# SECRETS: the three __SECRET__ values below are NEVER stored in a tracked file. At
# deploy they are decrypted from crew-secrets and appended to this file (root 0600).
# Presence-check them with ${VAR:+SET} only, never ${VAR:-...}. See README.md.

# ---- Submission listeners (GATED for public exposure) ----------------------
# Build/test loopback NOW. Do NOT bind 587 publicly until Conrad opens ufw + a real
# cert is in place. Loopback test value:
SUBMISSION_LISTENERS=127.0.0.1:1587:starttls
# Public value (only after the gated exposure flip):
# SUBMISSION_LISTENERS=587:starttls,465:implicit

# TLS for the submission hostname. AUTH is offered ONLY over TLS, so a cert is
# always required (a self-signed local cert is fine for loopback tests; a real cert
# for the public hostname is GATED). The daemon hot-reloads on renewal.
SUBMISSION_TLS_CERT=/etc/postern-submission/cert.pem
SUBMISSION_TLS_KEY=/etc/postern-submission/key.pem
SUBMISSION_HOSTNAME=smtp.skyphusion.org

# ---- Send hand-off to the worker /api/send ---------------------------------
POSTERN_SEND_URL=https://postern.skyphusion.org/api/send
POSTERN_SEND_TOKEN=__SECRET__ # mailbox API token; from crew-secrets, appended at deploy

# ---- Auth backend ----------------------------------------------------------
# This file is the HOST (systemd) deploy, whose fleet default is PAM (below).
#
# CONTAINER (Swarm) DEPLOYS USE AUTH_BACKEND=ldap (DIRECT-BIND + self-read), NOT
# PAM. The published image (ghcr.io/skyphusion-labs/postern-relay) is cgo-free, so
# the system/PAM backend is not compiled in. On the fleet the container binds
# DIRECTLY as the authenticating user (no privileged service account; Authentik
# 2024.12.3 has none to give) and then SELF-READS that user's own entry: the relay
# enforces From == mail so it reads the `mail` attr, and the memberOf=mail-users
# authorization gate is enforced on the same self-read (LDAP_REQUIRE_GROUP). See
# docs/AUTH-CONTRACT.md section 5b and the LDAP block below; container wiring lives in
# fleet-chezmoi postern-submission.stack.yml.
#
# HOST default: PAM (the fleet default; "PAM on both doors").
# Authenticates the Authentik user via /etc/pam.d/postern -> common-auth -> pam_ldap
# -> nslcd. Bound/From identity = <login>@AUTH_SYSTEM_DOMAIN. Requires the binary be
# built `-tags pam` (the default cgo-free build rejects AUTH_BACKEND=system).
AUTH_BACKEND=system
AUTH_SYSTEM_DOMAIN=skyphusion.org
AUTH_SYSTEM_PAM_SERVICE=postern

# Direct-LDAP (direct-bind + self-read; the container/Swarm posture, and the
# off-fleet alternative to PAM). TLS to the directory is mandatory: on the fleet the
# outpost publishes plaintext 389 only, so pin its leaf with LDAP_TLS_PIN_SHA256
# over StartTLS (see docs/AUTH-CONTRACT.md sections 5b + 6a). No service account, no
# bind password. Uncomment to use instead of PAM:
# AUTH_BACKEND=ldap
# LDAP_URL=ldap://192.0.2.10:389
# LDAP_STARTTLS=true
# LDAP_TLS_PIN_SHA256=__LEAF_SHA256__   # non-secret; openssl ... -fingerprint -sha256
# LDAP_BIND_DN_TEMPLATE=cn=%s,ou=users,dc=ldap,dc=goauthentik,dc=io
# LDAP_REQUIRE_GROUP=cn=mail-users,ou=groups,dc=ldap,dc=goauthentik,dc=io
# LDAP_MAIL_ATTR=mail
# LDAP_GROUP_ATTR=memberOf
# TLS trust to the directory (two mutually-exclusive models; see docs/AUTH-CONTRACT.md
# section 6). By default the cert is verified against the system roots.
#
# (A) Fingerprint-pin -- pin the EXACT leaf by SHA-256, SAN-independent. This is the
# mechanism for Authentik's DEFAULT outpost cert, whose only SAN is the bare wildcard
# `*` (which matches no name in modern Go, so the CA-pin below cannot verify it).
# The fingerprint is a NON-secret public value (a plain env, not a swarm secret).
# Capture it with:
#   openssl s_client -connect 192.0.2.10:389 -starttls ldap </dev/null 2>/dev/null \
#     | openssl x509 -fingerprint -sha256 -noout
# InsecureSkipVerify is set under the hood ONLY so the pin callback is the sole gate;
# it is an EXACT cert pin (stricter than a CA, MITM-resistant), NOT a bypass.
# LDAP_TLS_PIN_SHA256=86:54:79:...:88
#
# (B) CA-pin -- chain to a pinned private CA + verify the SANs. Use ONLY for a cert
# with a USABLE name (the future 636/chained-cert path), NOT the bare-* default.
# LDAP_TLS_CA, when set, is the ONLY trust anchor (an exact pin, not added to the
# system roots). LDAP_TLS_SERVER_NAME is the name verified against the cert SANs;
# defaults to the LDAP_URL host. Mutually exclusive with LDAP_TLS_PIN_SHA256.
# LDAP_TLS_CA=/run/secrets/postern_ldap_ca
# LDAP_TLS_SERVER_NAME=ldap.internal
# Directory dial + bind/search timeout in seconds (#88), so a dead/slow directory
# cannot hang a login. Default 10. 0 disables (not recommended). Distinct from
# POSTERN_API_TIMEOUT (the store-API timeout).
# LDAP_TIMEOUT=10

# ---- Online brute-force throttle on the AUTH door (#105) --------------------
# Per-ACCOUNT failure counter + lockout/backoff. Keyed on the account, not the
# source IP: behind the bastion every public connection is one IP, so per-IP is
# blind. A throttled attempt returns the same generic auth failure as a wrong
# password (enumeration-safe). These knob names are shared 1:1 with the Python
# IMAP checker's LOGIN throttle -- set one set of values for both doors.
# AUTH_THROTTLE_ENABLED=true                 # master switch (default true)
# AUTH_THROTTLE_MAX_FAILURES=5               # per-account consecutive failures before lockout
# AUTH_THROTTLE_LOCKOUT_SECONDS=60           # base lockout; doubles per failure past the threshold
# AUTH_THROTTLE_MAX_LOCKOUT_SECONDS=900      # cap on the per-account backoff
# AUTH_THROTTLE_GLOBAL_MAX_FAILURES=100      # aggregate failures in the window before a global cooldown (0 = off)
# AUTH_THROTTLE_GLOBAL_WINDOW_SECONDS=60     # the aggregate window + cooldown duration

# ---- PROXY protocol (real client IP behind the L4 load balancer, #155) ------
# The mail edge moved to a single L4 load balancer that targets the directory host
# directly. An L4 LB rewrites the source address, so the door recovers the REAL
# client IP from a PROXY header the LB prepends. HONORED ONLY from a trusted source
# (anti-spoof). Config names are shared 1:1 with the Python 993 door; full contract
# in docs/PROXY-PROTOCOL.md.
#   off      = disabled; raw peer always (DEFAULT; correct for mesh-internal / dev direct)
#   optional = trusted peer MAY send a header; a missing header falls back to raw peer
#   require  = trusted peer MUST send a header; trusted-without-header and any
#              untrusted peer are rejected (the production posture once the LB is live)
# PROXY_PROTOCOL_TRUSTED is REQUIRED whenever the mode is optional/require: the
# LB's private source as a comma-separated CIDR list (a bare IP = /32 or /128).
# CUTOVER ORDER IS HARD (docs/PROXY-PROTOCOL.md section 5): deploy with `optional`
# FIRST, THEN enable proxy-protocol at the LB, THEN optionally tighten to `require`.
# Enabling the LB flag before the door parses headers takes the service DOWN.
# PROXY_PROTOCOL=off
# PROXY_PROTOCOL_TRUSTED=192.0.2.0/24
# PROXY_PROTOCOL_TIMEOUT_SECONDS=5           # bound on reading the header (floored at 1s)

# ---- Inbound destination (NOT set in submission-only mode) -----------------
# As of #93 the relay keys inbound intake off the DESTINATION, not off SMTP_LISTEN.
# A submission-only deploy leaves the inbound vars unset, so the relay binds NO
# inbound intake port: no more dead loopback stub (the old 2587 wart is gone). Leave
# SMTP_LISTEN unset too; a leftover value only triggers a startup WARNING that intake
# is disabled. Uncomment the two lines below ONLY if this instance should ALSO accept
# inbound mail (then POSTERN_TRANSPORT_TOKEN=__SECRET__ becomes required as well).
# POSTERN_INGEST_URL=https://postern.skyphusion.org/ingest
# POSTERN_TRANSPORT_TOKEN=__SECRET__ # transport token; from crew-secrets, appended at deploy
