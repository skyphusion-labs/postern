# Copy to /etc/postern-submission.env (root 0600). Read by postern-submission.service.
# This is the 587 authenticated SMTP submission door (the relay binary built `-tags pam`).
# It is a SEPARATE instance from the loopback inbound relay; do not collide its ports.
#
# SECRETS: the three __SECRET__ values below are NEVER stored in a tracked file. At
# deploy they are decrypted from crew-secrets and appended to this file (root 0600).
# Presence-check them with ${VAR:+SET} only, never ${VAR:-...}. See SUBMISSION-DEPLOY.md.

# ---- Submission listeners (GATED for public exposure) ----------------------
# Build/test loopback NOW. Do NOT bind 587 publicly until Conrad opens ufw + a real
# cert is in place. Loopback test value:
SUBMISSION_LISTENERS=127.0.0.1:1587:starttls
# Public value (only after the gated exposure flip):
# SUBMISSION_LISTENERS=587:starttls,465:implicit

# TLS for the submission hostname. AUTH is offered ONLY over TLS, so a cert is
# always required (a self-signed local cert is fine for loopback tests; a real cert
# for the public hostname is GATED). The daemon hot-reloads on renewal.
SUBMISSION_TLS_CERT=/etc/postern-submission/cert.pem
SUBMISSION_TLS_KEY=/etc/postern-submission/key.pem
SUBMISSION_HOSTNAME=smtp.skyphusion.org

# ---- Send hand-off to the worker /api/send ---------------------------------
POSTERN_SEND_URL=https://postern.skyphusion.org/api/send
POSTERN_SEND_TOKEN=__SECRET__ # mailbox API token; from crew-secrets, appended at deploy

# ---- Auth backend: PAM (the fleet default; "PAM on both doors") ------------
# Authenticates the Authentik user via /etc/pam.d/postern -> common-auth -> pam_ldap
# -> nslcd. Bound/From identity = <login>@AUTH_SYSTEM_DOMAIN. Requires the binary be
# built `-tags pam` (the default cgo-free build rejects AUTH_BACKEND=system).
AUTH_BACKEND=system
AUTH_SYSTEM_DOMAIN=skyphusion.org
AUTH_SYSTEM_PAM_SERVICE=postern

# Direct-LDAP alternative (portable / off-fleet; on the fleet needs 636+cert first,
# see docs/AUTH-CONTRACT.md section 6). Uncomment to use instead of PAM:
# AUTH_BACKEND=ldap
# LDAP_URL=ldaps://dischord.internal:636
# LDAP_BIND_DN=cn=postern-mail-ro,ou=users,dc=ldap,dc=goauthentik,dc=io
# LDAP_BIND_PASSWORD=__SECRET__
# LDAP_SEARCH_BASE=ou=users,dc=ldap,dc=goauthentik,dc=io
# LDAP_SEARCH_FILTER=(&(mail=%s)(memberOf=cn=mail-users,ou=groups,dc=ldap,dc=goauthentik,dc=io))
# LDAP_MAIL_ATTR=mail
# Directory dial + bind/search timeout in seconds (#88), so a dead/slow directory
# cannot hang a login. Default 10. 0 disables (not recommended). Distinct from
# POSTERN_API_TIMEOUT (the store-API timeout).
# LDAP_TIMEOUT=10

# ---- Inbound destination (NOT set in submission-only mode) -----------------
# As of #93 the relay keys inbound intake off the DESTINATION, not off SMTP_LISTEN.
# A submission-only deploy leaves the inbound vars unset, so the relay binds NO
# inbound intake port: no more dead loopback stub (the old 2587 wart is gone). Leave
# SMTP_LISTEN unset too; a leftover value only triggers a startup WARNING that intake
# is disabled. Uncomment the two lines below ONLY if this instance should ALSO accept
# inbound mail (then POSTERN_TRANSPORT_TOKEN=__SECRET__ becomes required as well).
# POSTERN_INGEST_URL=https://postern.skyphusion.org/ingest
# POSTERN_TRANSPORT_TOKEN=__SECRET__ # transport token; from crew-secrets, appended at deploy
