{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "skyphusion-email-inbound",
  "main": "src/index.ts",
  "compatibility_date": "2025-05-05",
  "observability": { "enabled": true },

  // D1 database for message storage.
  // Create once: wrangler d1 create skyphusion-mail
  // Apply schema: wrangler d1 execute skyphusion-mail --file=schema.sql
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "skyphusion-mail",
      "database_id": "512c44f1-008b-43f7-8572-208aaaf55546"
    }
  ],

  // Vectorize index for semantic recall.
  // Create once: wrangler vectorize create skyphusion-mail-vec --dimensions=768 --metric=cosine
  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "skyphusion-mail-vec"
    }
  ],

  // R2 bucket for inbound attachment bytes (metadata + key go in D1.attachments).
  // Create once: wrangler r2 bucket create skyphusion-mail-attachments
  "r2_buckets": [
    { "binding": "ATTACHMENTS", "bucket_name": "skyphusion-mail-attachments" }
  ],

  // AI binding for bge-base embeddings, routed through the AI Gateway.
  "ai": {
    "binding": "AI",
    "gateway": {
      "id": "skyphusion-llm"
    }
  },

  // Cloudflare Email Sending binding (M2: #23). The default outbound transport
  // for the mailbox send/reply API. Same binding the standalone send worker
  // uses; here it lives alongside the store so a sent copy is written in the
  // same isolate (CONTRACT section 6).
  "send_email": [
    { "name": "EMAIL" }
  ],

  "vars": {
    // Comma-separated list of trusted sender domains or full addresses.
    // Senders must also pass SPF or DKIM to get trusted=1.
    "TRUSTED_SENDER_DOMAINS": "skyphusion.org,skyphusion.net,rockenhaus.net,cloudflare.com,notify.cloudflare.com,github.com,notifications.github.com,healthchecks.io,hetzner.com,runpod.io",

    // Transparent forward destination. Worker stores every inbound message in
    // D1 + Vectorize, then re-delivers the original envelope here. Set to "" to
    // disable forwarding (store-only mode).
    "FORWARD_TO": "conrad@rockenhaus.net",

    // Only forward when message.to matches one of these addresses (comma-separated).
    // Crew addresses are stored in D1 but not forwarded -- their mail is their own.
    "FORWARD_FOR": "conrad@skyphusion.org,alerts@skyphusion.org",

    // Addresses whose mail is embedded + indexed in Vectorize for crew RAG.
    // Crew members opt in by adding their own address here.
    "VECTORIZE_FOR": "conrad@skyphusion.org,alerts@skyphusion.org,strummer@skyphusion.org,rollins@skyphusion.org,mackaye@skyphusion.org",

    // Outbound send/reply (M2). DEFAULT_FROM must be on ALLOWED_FROM_DOMAIN.
    // OUTBOUND_TRANSPORT unset/"cf" = Cloudflare Email Sending (default).
    "DEFAULT_FROM": "noreply@skyphusion.org",
    "DEFAULT_FROM_NAME": "Skyphusion",
    "ALLOWED_FROM_DOMAIN": "skyphusion.org",
    "OUTBOUND_TRANSPORT": "cf"
  }

  // POSTERN_API_TOKEN is a secret, not a var (gates the send/reply + read API):
  //   npx wrangler secret put POSTERN_API_TOKEN
  // (RELAY_TOKEN is still read as a fallback for one release through the rename.)

  // Email Routing rules (CF Dashboard -> Email -> Email Routing -> Routing Rules):
  //   Route ALL addresses (including catch-all) to Worker skyphusion-email-inbound.
  //   The worker handles forwarding to FORWARD_TO after ingestion.
  //   Remove any direct "Forward to email" rules -- everything goes through the worker.
}
