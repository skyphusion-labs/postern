{
  "name": "skyphusion-email-inbound",
  "version": "1.0.1",
  "private": true,
  "description": "CF Email Worker: ingests inbound mail into D1 + Vectorize for agent consumption",
  "scripts": {
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "sync-webmail": "node scripts/sync-webmail.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.enabled=true --coverage.provider=istanbul --coverage.reporter=cobertura --coverage.reporter=text",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "postal-mime": "^2.7.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260715.1",
    "@vitest/coverage-istanbul": "^4.1.9",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
