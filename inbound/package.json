{
  "name": "skyphusion-email-inbound",
  "version": "0.1.0",
  "private": true,
  "description": "CF Email Worker: ingests inbound mail into D1 + Vectorize for agent consumption",
  "scripts": {
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.enabled=true --coverage.provider=istanbul --coverage.reporter=cobertura --coverage.reporter=text",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "postal-mime": "^2.7.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250505.0",
    "@vitest/coverage-istanbul": "^4.1.9",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.102.0"
  }
}
